# ====================================================================
# HVRBOR.CLUB — environment variables
# ====================================================================
# Copy to .env.local and fill what you need. The site works without any
# of these; they upgrade form submissions from console-log fallback to
# real outbound email via Resend.

# Resend
# Set RESEND_API_KEY to enable real email delivery for /api/apply,
# /api/newsletter, /api/bottle-episode. Without this, submissions
# log to the server console and the user-facing flow still succeeds.
RESEND_API_KEY=

# From address used on outbound notifications
RESEND_FROM=notifications@hvrbor.club

# Inboxes (defaults to hello@hvrbor.club for all three if unset)
APPLY_INBOX=hello@hvrbor.club
BOTTLE_INBOX=hello@hvrbor.club
NEWSLETTER_INBOX=hello@hvrbor.club
